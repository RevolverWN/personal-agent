# ============================================
# Personal Agent - Environment Configuration
# ============================================

# Application Settings
APP_NAME=Personal Agent
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
DATABASE_URL=sqlite+aiosqlite:///./data/personal_agent.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/personal_agent

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# LLM API Keys (Add your own keys)
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-...

# OpenRouter (Unified API)
OPENROUTER_API_KEY=sk-or-...

# Default Model Configuration
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# Tool Configuration
ENABLE_WEB_SEARCH=true
ENABLE_FILE_OPERATIONS=true

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/personal_agent.log
